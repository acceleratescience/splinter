# =============================================================================
# Environment Configuration for LiteLLM/vLLM Stack
# =============================================================================
# 
# IMPORTANT: 
#   - Copy this to .env and fill in real values
#   - Never commit .env to git (it should be in the .gitignore)
#   - Keep this .env.example as a template
#
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=litellm
POSTGRES_USER=ADMIN_STYLE_USER
POSTGRES_PASSWORD=CHANGE_ME_TO_SOMETHING_SECURE

# -----------------------------------------------------------------------------
# LiteLLM
# -----------------------------------------------------------------------------
LITELLM_MASTER_KEY=sk-CHANGE_ME_TO_SOMETHING_SECURE
LITELLM_PORT=4000

# -----------------------------------------------------------------------------
# vLLM
# -----------------------------------------------------------------------------
VLLM_VERSION=vX.X.X

# -----------------------------------------------------------------------------
# Nginx / Domain
# -----------------------------------------------------------------------------
DOMAIN=YOUR.DOMAIN.HERE

# -----------------------------------------------------------------------------
# TLS (set after running certbot for the first time)
# Standard Let's Encrypt paths: /etc/letsencrypt/live/DOMAIN/
# -----------------------------------------------------------------------------
SSL_CERT_PATH=/etc/letsencrypt/live/YOUR.DOMAIN.HERE/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/YOUR.DOMAIN.HERE/privkey.pem