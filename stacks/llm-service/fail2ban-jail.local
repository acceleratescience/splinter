[sshd]
enabled = true
maxretry = 3
findtime = 3600
bantime = 86400
bantime.increment = true
bantime.factor = 24

[nginx-llm-blocked]
enabled = true
port = http,https
filter = nginx-llm-blocked
logpath = /var/log/nginx/access.log
backend = auto
maxretry = 3
findtime = 60
bantime = 86400

[nginx-llm-auth]
enabled = true
port = http,https
filter = nginx-llm-auth
logpath = /var/log/nginx/access.log
backend = auto
maxretry = 5
findtime = 60
bantime = 3600

[nginx-llm-login]
enabled = true
port = http,https
filter = nginx-llm-login
logpath = /var/log/nginx/access.log
backend = auto
maxretry = 5
findtime = 300
bantime = 3600
